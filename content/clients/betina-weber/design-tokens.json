  "colorDecisionRationale": {
    "rejectedPaths": [
      {
        "path": "Saturated accent #CA8A04 (Betina's raw draft)",
        "reason": "96% saturação escorrega pra mostarda em monitores diferentes; CTA sólido em âmbar saturado contradiz vetor verbal 'autoridade calma'"
      },
      {
        "path": "Monochromatic rigor (v1.0 original)",
        "reason": "Ausência total de acento deixa marca genérica dentro da categoria advisory premium; monocromático puro é padrão de estúdio de design, não de board advisor"
      }
    ],
    "adoptedPath": {
      "name": "Hybrid calibrated",
      "description": "Paleta warm + accent bronze dessaturado usado só como assinatura editorial",
      "achieves": "Preserva autoridade calma, ganha reconhecimento cromático, respeita intenção original refinando execução"
    }
  },
  "font": {
    "family": {
      "serif": { "value": "Spectral, 'Times New Roman', Georgia, serif" },
      "sans":  { "value": "'TASA Orbiter', Inter, ui-sans-serif, system-ui, sans-serif" }
    },
    "weight": {
      "serif200": { "value": 200 },
      "serif300": { "value": 300 },
      "sans400":  { "value": 400 },
      "sans500":  { "value": 500 }
    },
    "rejectedAlternative": {
      "alt": "Playfair Display + Inter (rascunho pessoal)",
      "reason": "Playfair é onipresente em advisory firms (genérico); Spectral posiciona como singular. Inter é funcional mas sem caráter; TASA Orbiter tem humanismo executivo."
    }
  },
