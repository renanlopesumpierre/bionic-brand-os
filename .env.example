# TAG Brand Interface - Environment Variables
# Copy to .env.local for development.

# --- Brand Agent providers ---

# Primary: Anthropic (Claude Sonnet 4.6 with prompt caching).
# Used when user has not provided their own key (BYOK).
ANTHROPIC_API_KEY=

# Fallback: Groq (Llama 3.3 70B, free tier).
# Used when no Anthropic key is available.
GROQ_API_KEY=

# --- Rate limiting (optional in dev, required in prod) ---

# Upstash Redis REST credentials. Without these, rate limit is disabled.
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Auth (for future private areas) ---

# Resend for magic link emails. Optional in v1.
RESEND_API_KEY=
AUTH_SECRET=

# --- Site ---

# Used for Open Graph metadata, sitemap, absolute URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
